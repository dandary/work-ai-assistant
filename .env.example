# Скопируйте в .env.local (предпочтительно для Next.js) или в .env.
# Не вставляйте реальные пароли в этот файл — только в .env / .env.local (они в .gitignore).

# Neon → проект → Connect:
#  - Pooled (часто хост с «-pooler») → DATABASE_URL
#  - Direct (без «-pooler») → DIRECT_URL

DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

AUTH_SECRET=
CEREBRAS_API_KEY=

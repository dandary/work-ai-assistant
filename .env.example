# Скопируйте в .env.local (предпочтительно для Next.js) или в .env.
# Секреты не должны попадать в git — см. .gitignore (игнорируются .env, .env.local и т.д.)

# Neon → проект → Connect / Connection string:
#  - «Pooled» / serverless — для DATABASE_URL (часто хост с «-pooler» в имени)
#  - «Direct» / без пулинга — для DIRECT_URL (миграции prisma migrate)

DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# На первый тест можно одинаковую строку в оба поля; для прод лучше разделить pooled / direct.

AUTH_SECRET=
CEREBRAS_API_KEY=

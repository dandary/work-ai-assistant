# Cerebras Cloud — https://cloud.cerebras.ai/ (ключ обычно с префиксом csk-)
CEREBRAS_API_KEY=

# База OpenAI-совместимого API (по умолчанию https://api.cerebras.ai/v1)
# CEREBRAS_API_BASE_URL=https://api.cerebras.ai/v1

# Модель по умолчанию, если клиент не передаёт (см. также выбор модели в UI)
# CEREBRAS_MODEL=llama3.1-8b

# Доступные id в приложении: gpt-oss-120b, zai-glm-4.7, qwen-3-235b-a22b-instruct-2507, llama3.1-8b

# Таймаут запроса в мс (по умолчанию 300000)
# CEREBRAS_REQUEST_TIMEOUT_MS=300000

# Повторы при 429/503 (по умолчанию 6)
# CEREBRAS_MAX_RETRIES=6

# Лимит частоты запросов к /api/assistant (на один инстанс, по IP из X-Forwarded-For)
# ASSISTANT_RATE_LIMIT_MAX=60
# ASSISTANT_RATE_LIMIT_WINDOW_MS=60000
# ASSISTANT_RATE_LIMIT_DISABLED=1
